OPENCLAW_CONFIG_DIR=/c/Users/User/.openclaw
OPENCLAW_WORKSPACE_DIR=/c/Users/User/.openclaw/workspace
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_TOKEN=replace-with-random-token
OPENCLAW_CONTROL_UI_ALLOWED_ORIGINS=
OPENCLAW_IMAGE=openclaw:local
OPENCLAW_NPM_SPEC=openclaw@latest
OPENCLAW_EXTRA_MOUNTS=
OPENCLAW_HOME_VOLUME=
OPENCLAW_DOCKER_APT_PACKAGES=bash git gh
PINCHTAB_TOKEN=replace-with-random-token
CLAUDE_AI_SESSION_KEY=
CLAUDE_WEB_SESSION_KEY=
CLAUDE_WEB_COOKIE=
# Git identity for agent commits — uncomment and fill in your own details.
# If unset, git falls back to ~/.gitconfig inside the container.
# GIT_AUTHOR_NAME=Your Name
# GIT_AUTHOR_EMAIL=you@example.com
# GIT_COMMITTER_NAME=Your Name
# GIT_COMMITTER_EMAIL=you@example.com
GOOGLE_CLIENT_ID=xxx
GOOGLE_CLIENT_SECRET=xxx
GOOGLE_REFRESH_TOKEN=xxx
GITHUB_TOKEN=
# LLM auth mode — controls how providers are authenticated.
#   oauth    — use `make login` (ChatGPT Team / Claude Team web accounts, no API credits needed)
#   api_key  — use API keys below (requires separate API credits)
LLM_AUTH_MODE=oauth

# API keys — only needed when LLM_AUTH_MODE=api_key
# OpenAI key: platform.openai.com/api-keys
OPENAI_API_KEY=
# Anthropic key: platform.anthropic.com/settings/keys (requires separate API credits)
ANTHROPIC_API_KEY=
AZURE_DEVOPS_TOKEN=
AZURE_DEVOPS_ORG=
AZURE_DEVOPS_PROJECT=
AGENT_MAX_CONCURRENCY=1
AGENT_DRY_RUN=false
AGENT_POLL_INTERVAL_SECS=300
